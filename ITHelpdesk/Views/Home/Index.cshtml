@{
    ViewData["Title"] = "IT Helpdesk";
}

<div class="p-4 p-md-5 mb-4 rounded-3 bg-light border">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">IT Helpdesk and Ticketing</h1>
        <p class="col-md-9 fs-5">
            Submit IT issues, attach screenshots, track resolution status, and collaborate with technicians.
            Staff members can triage, assign, and resolve tickets in one workflow.
        </p>
        <a class="btn btn-primary btn-lg" asp-controller="Tickets" asp-action="Index">Go to Tickets</a>
    </div>
</div>
