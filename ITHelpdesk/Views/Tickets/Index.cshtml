@model TicketIndexViewModel
@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Support Tickets</h1>
    <a class="btn btn-primary" asp-action="Create">Submit Ticket</a>
</div>

<div class="row g-2 mb-3">
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body py-2">
                <div class="text-muted small">Visible</div>
                <div class="h5 mb-0">@Model.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body py-2">
                <div class="text-muted small">Open</div>
                <div class="h5 mb-0">@Model.OpenCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body py-2">
                <div class="text-muted small">In Progress</div>
                <div class="h5 mb-0">@Model.InProgressCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body py-2">
                <div class="text-muted small">Resolved</div>
                <div class="h5 mb-0">@Model.ResolvedCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body py-2">
                <div class="text-muted small">Unassigned</div>
                <div class="h5 mb-0">@Model.UnassignedCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card shadow-sm border border-danger-subtle">
            <div class="card-body py-2">
                <div class="text-muted small">Overdue</div>
                <div class="h5 mb-0 text-danger">@Model.OverdueCount</div>
            </div>
        </div>
    </div>
</div>

<form method="get" class="card shadow-sm p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
            <label class="form-label" for="searchTerm">Search</label>
            <input class="form-control" type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Title or description" />
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label" for="statusId">Status</label>
            <select class="form-select" id="statusId" name="statusId">
                <option value="">All statuses</option>
                @foreach (var status in Model.Statuses)
                {
                    if (Model.SelectedStatusId == status.Id)
                    {
                        <option value="@status.Id" selected>@status.Name</option>
                    }
                    else
                    {
                        <option value="@status.Id">@status.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label" for="priority">Priority</label>
            <select class="form-select" id="priority" name="priority">
                <option value="">All priorities</option>
                @if (Model.SelectedPriority == TicketPriority.Low)
                {
                    <option value="@((int)TicketPriority.Low)" selected>Low</option>
                }
                else
                {
                    <option value="@((int)TicketPriority.Low)">Low</option>
                }
                @if (Model.SelectedPriority == TicketPriority.Normal)
                {
                    <option value="@((int)TicketPriority.Normal)" selected>Normal</option>
                }
                else
                {
                    <option value="@((int)TicketPriority.Normal)">Normal</option>
                }
                @if (Model.SelectedPriority == TicketPriority.High)
                {
                    <option value="@((int)TicketPriority.High)" selected>High</option>
                }
                else
                {
                    <option value="@((int)TicketPriority.High)">High</option>
                }
                @if (Model.SelectedPriority == TicketPriority.Critical)
                {
                    <option value="@((int)TicketPriority.Critical)" selected>Critical</option>
                }
                else
                {
                    <option value="@((int)TicketPriority.Critical)">Critical</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
    </div>

    @if (Model.CanManage)
    {
        <div class="row g-2 mt-1">
            <div class="col-auto form-check ms-2">
                <input class="form-check-input" type="checkbox" id="onlyUnassigned" name="onlyUnassigned" value="true" checked="@(Model.OnlyUnassigned ? "checked" : null)" />
                <label class="form-check-label" for="onlyUnassigned">Unassigned only</label>
            </div>
            <div class="col-auto form-check">
                <input class="form-check-input" type="checkbox" id="onlyMyAssigned" name="onlyMyAssigned" value="true" checked="@(Model.OnlyMyAssigned ? "checked" : null)" />
                <label class="form-check-label" for="onlyMyAssigned">Assigned to me</label>
            </div>
        </div>
    }
</form>

@if (!Model.Tickets.Any())
{
    <div class="alert alert-info">No tickets found yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Due</th>
                    <th>Created By</th>
                    <th>Assigned To</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    <tr>
                        <td>@ticket.Id</td>
                        <td>@ticket.Title</td>
                        <td><span class="badge bg-secondary">@ticket.StatusName</span></td>
                        <td>
                            @if (ticket.Priority == TicketPriority.Critical)
                            {
                                <span class="badge text-bg-danger">Critical</span>
                            }
                            else if (ticket.Priority == TicketPriority.High)
                            {
                                <span class="badge text-bg-warning">High</span>
                            }
                            else if (ticket.Priority == TicketPriority.Low)
                            {
                                <span class="badge text-bg-success">Low</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Normal</span>
                            }
                        </td>
                        <td>
                            @if (ticket.DueAtUtc.HasValue)
                            {
                                if (ticket.IsOverdue)
                                {
                                    <span class="text-danger fw-semibold">@ticket.DueAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                }
                                else
                                {
                                    @ticket.DueAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                }
                            }
                            else
                            {
                                <span class="text-muted">Not set</span>
                            }
                        </td>
                        <td>@ticket.CreatedByDisplayName</td>
                        <td>@(ticket.AssignedToDisplayName ?? "Unassigned")</td>
                        <td>@ticket.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@ticket.Id">View</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@ticket.Id">Edit</a>
                                <form asp-action="Delete" asp-route-id="@ticket.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this ticket?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
