@model TicketDetailsViewModel
@{
    ViewData["Title"] = "Ticket Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Ticket #@Model.Ticket.Id</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Ticket.Id">Edit</a>
        <form asp-action="Delete" asp-route-id="@Model.Ticket.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this ticket?');">
            <button type="submit" class="btn btn-outline-danger">Delete</button>
        </form>
        <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h2 class="h5">@Model.Ticket.Title</h2>
                <p class="mb-3">@Model.Ticket.Description</p>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Ticket.Status?.Name</span></dd>

                    <dt class="col-sm-4">Priority</dt>
                    <dd class="col-sm-8">
                        @if (Model.Ticket.Priority == TicketPriority.Critical)
                        {
                            <span class="badge text-bg-danger">Critical</span>
                        }
                        else if (Model.Ticket.Priority == TicketPriority.High)
                        {
                            <span class="badge text-bg-warning">High</span>
                        }
                        else if (Model.Ticket.Priority == TicketPriority.Low)
                        {
                            <span class="badge text-bg-success">Low</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Normal</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Target Due</dt>
                    <dd class="col-sm-8">
                        @if (Model.Ticket.DueAtUtc.HasValue)
                        {
                            if (Model.IsOverdue)
                            {
                                <span class="text-danger fw-semibold">@Model.Ticket.DueAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") (Overdue)</span>
                            }
                            else
                            {
                                @Model.Ticket.DueAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            }
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created By</dt>
                    <dd class="col-sm-8">@Model.CreatedByDisplayName</dd>

                    <dt class="col-sm-4">Assigned To</dt>
                    <dd class="col-sm-8">@(Model.AssignedToDisplayName ?? "Unassigned")</dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.Ticket.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Ticket.ScreenshotPath))
                {
                    <hr />
                    <p class="mb-2 fw-semibold">Screenshot</p>
                    <a href="@Model.Ticket.ScreenshotPath" target="_blank" rel="noopener noreferrer">
                        <img src="@Model.Ticket.ScreenshotPath" alt="Ticket screenshot" class="img-fluid border rounded" style="max-height:400px;" />
                    </a>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Comments</h2>

                @if (!Model.Ticket.Comments.Any())
                {
                    <p class="text-muted">No comments yet.</p>
                }
                else
                {
                    @foreach (var comment in Model.Ticket.Comments.OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <div class="border rounded p-2 mb-2">
                            <div class="small text-muted mb-1">
                                @Model.CommentAuthorDisplayNames.GetValueOrDefault(comment.AuthorUserId, comment.AuthorUserId)
                                - @comment.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>
                            <div>@comment.CommentText</div>
                        </div>
                    }
                }

                <form asp-action="AddComment" method="post" class="mt-3">
                    <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                    <div class="mb-2">
                        <label class="form-label" for="commentText">Add Comment</label>
                        <textarea class="form-control" id="commentText" name="commentText" rows="3" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Timeline</h2>
                @if (!Model.Ticket.Activities.Any())
                {
                    <p class="text-muted mb-0">No activity yet.</p>
                }
                else
                {
                    @foreach (var activity in Model.Ticket.Activities.OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <div class="border-start border-3 ps-3 py-2 mb-2">
                            <div class="small text-muted">
                                @if (!string.IsNullOrWhiteSpace(activity.ActorUserId))
                                {
                                    @Model.ActivityActorDisplayNames.GetValueOrDefault(activity.ActorUserId, activity.ActorUserId)
                                }
                                else
                                {
                                    <span>System</span>
                                }
                                - @activity.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>
                            <div>@activity.Description</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @if (Model.CanManage)
    {
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-3">Workflow</h2>
                    <form asp-action="UpdateWorkflow" method="post">
                        <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                        <div class="mb-2">
                            <label class="form-label" for="ticketStatusId">Status</label>
                            <select class="form-select" name="ticketStatusId">
                                @foreach (var status in Model.Statuses)
                                {
                                    if (status.Id == Model.Ticket.TicketStatusId)
                                    {
                                        <option value="@status.Id" selected>@status.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@status.Id">@status.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label" for="priority">Priority</label>
                            <select class="form-select" id="priority" name="priority">
                                @if (Model.Ticket.Priority == TicketPriority.Low)
                                {
                                    <option value="@((int)TicketPriority.Low)" selected>Low</option>
                                }
                                else
                                {
                                    <option value="@((int)TicketPriority.Low)">Low</option>
                                }
                                @if (Model.Ticket.Priority == TicketPriority.Normal)
                                {
                                    <option value="@((int)TicketPriority.Normal)" selected>Normal</option>
                                }
                                else
                                {
                                    <option value="@((int)TicketPriority.Normal)">Normal</option>
                                }
                                @if (Model.Ticket.Priority == TicketPriority.High)
                                {
                                    <option value="@((int)TicketPriority.High)" selected>High</option>
                                }
                                else
                                {
                                    <option value="@((int)TicketPriority.High)">High</option>
                                }
                                @if (Model.Ticket.Priority == TicketPriority.Critical)
                                {
                                    <option value="@((int)TicketPriority.Critical)" selected>Critical</option>
                                }
                                else
                                {
                                    <option value="@((int)TicketPriority.Critical)">Critical</option>
                                }
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label" for="dueAtUtc">Target Due Date</label>
                            <input class="form-control" id="dueAtUtc" name="dueAtUtc" type="datetime-local" value="@Model.Ticket.DueAtUtc?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label" for="assignedToUserId">Assigned To</label>
                            <select class="form-select" name="assignedToUserId">
                                <option value="">Unassigned</option>
                                @foreach (var tech in Model.Technicians)
                                {
                                    if (tech.Id == Model.Ticket.AssignedToUserId)
                                    {
                                        <option value="@tech.Id" selected>@tech.DisplayName</option>
                                    }
                                    else
                                    {
                                        <option value="@tech.Id">@tech.DisplayName</option>
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-outline-primary w-100">Save Workflow</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
